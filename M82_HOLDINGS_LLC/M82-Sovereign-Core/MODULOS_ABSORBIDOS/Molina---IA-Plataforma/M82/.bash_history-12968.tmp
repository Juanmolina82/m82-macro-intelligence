cat << 'EOF' > watchdog.js
const axios = require('axios');

async function getPrice() {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), 5000); // 5 segundos máximo

    try {
        const response = await axios.get('https://api.binance.com/api/v3/ticker/price?symbol=PAXGUSDT', {
            signal: controller.signal,
            headers: { 'User-Agent': 'Mozilla/5.0' + Math.random() } // Agente aleatorio
        });
        clearTimeout(id);
        return parseFloat(response.data.price).toFixed(2);
    } catch (e) {
        return null;
    }
}

async function m82_terminal() {
    const gold = await getPrice();
    const brent = 96.41; // Ref Captura Omán
    const wti = 88.78;

    console.clear();
    console.log("\n--- 🏛️ M82 ULTIMA | MOLINA HOLDINGS ---");
    console.log("DIPLOMACIA: KUSHNER/WITKOFF EN OMAN");
    console.log("HORA:  " + new Date().toLocaleTimeString());
    console.log("---------------------------------------");
    console.log("🛢️ BRENT:  $" + brent + "  |  WTI: $" + wti);
    
    if (gold) {
        console.log("✨ ORO:    $" + gold + " ✅");
    } else {
        console.log("✨ ORO:    📡 BUSCANDO SEÑAL...");
    }
    
    console.log("---------------------------------------");
    console.log("STATUS: " + (gold ? "OPERATIVO" : "FILTRADO POR RED"));
    console.log("---------------------------------------\n");
}

setInterval(m82_terminal, 4000);
m82_terminal();
EOF

