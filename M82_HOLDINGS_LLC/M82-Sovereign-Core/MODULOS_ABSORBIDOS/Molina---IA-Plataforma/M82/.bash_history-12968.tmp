cat << 'EOF' > watchdog.js
const axios = require('axios');

// Parámetros del Modelo Jump-Diffusion de Molina Holdings
const S_PRE_JUMP = 112.89; // Precio antes del titular de Trump
const THRESHOLD_JUMP = -0.05; // Alerta si el salto es > 5%

async function m82_quant_engine() {
    try {
        // Fetch de PAXG (Oro) vía Axios con Bypass
        const res = await axios.get('https://api.binance.com/api/v3/ticker/price?symbol=PAXGUSDT', {
            timeout: 5000,
            headers: { 'User-Agent': 'M82-Quant-v2' }
        });
        const gold = parseFloat(res.data.price);
        
        // Datos de Mercado Actuales (Ref: 09:54 AM)
        const brent = 98.84; // Rebote técnico detectado
        const wti = 90.72;   // Soporte clave
        
        // CÁLCULO MATEMÁTICO DEL SALTO (dJ_t)
        // dJ = (S_t / S_t-minus) - 1
        const jumpDelta = (brent / S_PRE_JUMP) - 1;
        const jumpPercentage = (jumpDelta * 100).toFixed(2);

        console.clear();
        console.log("\n--- 🏛️ M82 QUANT-ENGINE | MOLINA HOLDINGS ---");
        console.log("MODELO: JUMP-DIFFUSION (MERTON) | " + new Date().toLocaleTimeString());
        console.log("-------------------------------------------------");
        console.log(`🛢️ BRENT (S_t):   $${brent.toFixed(2)}  [Ref: $${S_PRE_JUMP}]`);
        console.log(`📉 JUMP DELTA (dJ): ${jumpPercentage}%`);
        console.log(`✨ GOLD (PAXG):  $${gold.toFixed(2)}`);
        console.log("-------------------------------------------------");

        // LÓGICA DE ALERTA DE SALTO DISCRETO
        if (jumpDelta <= THRESHOLD_JUMP) {
            console.log("🚨 ALERTA: EVENTO DE SALTO DETECTADO (Jump Event)");
            console.log("📢 CAUSA: NEGOCIACIONES KUSHNER/WITKOFF EN OMAN");
        } else {
            console.log("✅ ESTATUS: VOLATILIDAD DE DIFUSIÓN NORMAL");
        }

        console.log("-------------------------------------------------");
        console.log("📊 NOTA: ISRAEL 'HAPPY' = COMPRESIÓN DE PRIMA");
        console.log("-------------------------------------------------\n");

    } catch (e) {
        process.stdout.write("📡 Sincronizando dJ_t... ");
    }
}

setInterval(m82_quant_engine, 5000);
m82_quant_engine();
EOF

